# Provider to use: openai | siliconflow | ollama
PROVIDER=ollama

# OpenAI
# OPENAI_API_KEY=your_openai_api_key_here

# SiliconFlow
SILICONFLOW_API_KEY=your_siliconflow_api_key_here

# Ollama (local) — no API key required; talks to the native Ollama API via the
# official `ollama` package (not the OpenAI-compat shim). Override the host if needed.
OLLAMA_HOST=http://localhost:11435

# Model for evaluation (must match the selected provider)
# OpenAI examples:    gpt-4o-mini  gpt-4o
# SiliconFlow examples: Pro/zai-org/GLM-4.7  Pro/Qwen/Qwen2.5-VL-7B-Instruct
# Ollama example:     qwen3.5:latest  (thinking is enabled automatically for this provider)
EVA_MODEL=qwen3.5:latest

# Request timeout in seconds and retry count for a single sample (useful for slow/local models)
EVA_TIMEOUT=300
EVA_MAX_RETRIES=3
